# Example environment variables for docker-compose
# Rename to .env and fill values before running docker compose

# MSSQL SA password (must meet SQL Server complexity requirements)
SA_PASSWORD=Your_password123!

# Connection string for backend to connect to DB (used by docker-compose environment)
# For compose setup using service name 'db' and SA credentials above:
ConnectionStrings__DefaultConnection=Server=db,1433;Database=CloneGitHubDB;User Id=sa;Password=${SA_PASSWORD};TrustServerCertificate=true

# Comma or semicolon separated allowed origins for CORS (frontend origin)
ALLOWED_ORIGINS=http://localhost:3000

# ASPNETCORE environment
ASPNETCORE_ENVIRONMENT=Production
